<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- READ_MEDIA_IMAGES on Android 13+; the system Selected Photos flow
         covers the granular partial-grant case automatically. -->
    <uses-permission android:name="android.permission.READ_MEDIA_IMAGES" />

    <!-- ACCESS_MEDIA_LOCATION is the gate that lets MediaStore.setRequireOriginal
         hand back the unstripped file (with GPS EXIF) on Android 10+. -->
    <uses-permission android:name="android.permission.ACCESS_MEDIA_LOCATION" />

</manifest>
